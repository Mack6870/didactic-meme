# Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=3001
NODE_ENV=development

# AWS (uncomment and configure when ready)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# Database (uncomment the one you need)
# MONGODB_URI=mongodb://localhost:27017/didactic-meme
# POSTGRES_URI=postgresql://user:password@localhost:5432/didactic-meme
# DYNAMODB_TABLE_PREFIX=didactic-meme

# JWT / Auth (uncomment when ready)
# JWT_SECRET=your-jwt-secret
# JWT_EXPIRES_IN=7d
